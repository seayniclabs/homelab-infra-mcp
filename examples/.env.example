# Homelab Infrastructure MCP — environment template
# Copy to .env and fill in values. Never commit real credentials.

NPM_URL=http://localhost:81
NPM_EMAIL=<npm-admin-email>
NPM_PASSWORD=<npm-admin-password>

DOCKER_HOST=unix:///var/run/docker.sock
# Optional Portainer backend (replaces socket when both are set):
# PORTAINER_URL=http://localhost:9000
# PORTAINER_TOKEN=<portainer-api-token>
# PORTAINER_ENDPOINT_ID=1

DNS_PROVIDER=cloudflare
CLOUDFLARE_API_TOKEN=<cloudflare-api-token>
CLOUDFLARE_ZONE_ID=<default-zone-id>

HOMELAB_MCP_MODE=normal
HOMELAB_MCP_MODULES=npm,docker,dns
HOMELAB_MCP_LOG_LEVEL=INFO
HOMELAB_MCP_TRANSPORT=stdio
HOMELAB_MCP_PORT=8200
